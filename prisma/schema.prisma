generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon / Vercel: pooled URL ใน DATABASE_URL, direct (ไม่มี pgbouncer) ใน DIRECT_URL สำหรับ migrate
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum TemplateVersionStatus {
  DRAFT
  PUBLISHED
  DEPRECATED
  ARCHIVED
}

enum TemplateMarketplaceVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum TemplateTelemetryKind {
  STEP_START
  STEP_COMPLETE
  STEP_SKIP
  FLOW_COMPLETE
}

enum DeviceClass {
  MOBILE
  TABLET
  DESKTOP
  UNKNOWN
}

enum AuditOutcome {
  SUCCESS
  FAILURE
  DENIED
}

enum SystemLogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

enum SupportCaseStatus {
  NEW
  CLAIMED
  IN_PROGRESS
  WAITING_USER
  RESOLVED
  CLOSED
  SPAM
}

enum SupportCasePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportMessageVisibility {
  PUBLIC
  INTERNAL
}

enum SupportSenderType {
  USER
  ADMIN
  SYSTEM
  GUEST
}

/// Anonymous device identity (legacy + claim source)
model Creator {
  id          String   @id @default(uuid()) @db.Uuid
  deviceToken String   @unique @map("device_token")
  email       String?
  createdAt   DateTime @default(now()) @map("created_at")
  events      Event[]

  @@map("creators")
}

/// Authenticated account (email/password or Google)
model User {
  id                        String     @id @default(uuid()) @db.Uuid
  email                     String     @unique
  emailVerified             DateTime?  @map("email_verified")
  name                      String?
  image                     String?
  username                  String?    @unique
  phone                     String?
  passwordHash              String?    @map("password_hash")
  /// Account Security PIN (Admin) — ห้ามสับสนกับ Event.pinHash
  securityPinHash           String?    @map("security_pin_hash")
  securityPinSetAt          DateTime?  @map("security_pin_set_at")
  securityPinFailedAttempts Int        @default(0) @map("security_pin_failed_attempts")
  securityPinLockedUntil    DateTime?  @map("security_pin_locked_until")
  mustChangePassword        Boolean    @default(false) @map("must_change_password")
  mustChangeSecurityPin     Boolean    @default(false) @map("must_change_security_pin")
  /// Bump เพื่อ invalidate JWT session เก่า
  authVersion               Int        @default(0) @map("auth_version")
  role                      UserRole   @default(USER)
  status                    UserStatus @default(ACTIVE)
  createdAt                 DateTime   @default(now()) @map("created_at")
  updatedAt                 DateTime   @updatedAt @map("updated_at")
  accounts                  Account[]
  events                    Event[]    @relation("EventOwner")
  templateVersionsCreated   TemplateVersion[] @relation("TemplateVersionCreatedBy")
  templateVersionsPublished TemplateVersion[] @relation("TemplateVersionPublishedBy")
  auditLogsAsActor          AuditLog[] @relation("AuditActor")
  supportCasesAssigned      SupportCase[] @relation("SupportCaseAssignee")
  supportCasesLinked        SupportCase[] @relation("SupportCaseLinkedUser")
  supportConversations      SupportConversation[] @relation("SupportConversationUser")
  supportMessagesSent       SupportMessage[] @relation("SupportMessageSender")
  notifications             AppNotification[] @relation("NotificationRecipient")

  @@map("users")
}

/// OAuth provider accounts (Auth.js / Google)
model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Template {
  id                        String                         @id @default(uuid()) @db.Uuid
  slug                      String                         @unique
  name                      String
  description               String
  thumbnailUrl              String                         @map("thumbnail_url")
  /// Denormalized cache of current published steps_schema (catalog convenience only)
  stepsSchema               Json                           @map("steps_schema")
  isActive                  Boolean                        @default(true) @map("is_active")
  category                  String                         @default("birthday")
  tags                      String[]                       @default([])
  mood                      String                         @default("cute")
  previewUrl                String?                        @map("preview_url")
  requiredAssetCount        Int                            @default(0) @map("required_asset_count")
  isPremium                 Boolean                        @default(false) @map("is_premium")
  sortOrder                 Int                            @default(0) @map("sort_order")
  usageCount                Int                            @default(0) @map("usage_count")
  publishedAt               DateTime?                      @map("published_at")
  currentPublishedVersionId String?                        @unique @map("current_published_version_id") @db.Uuid
  marketplaceVisibility     TemplateMarketplaceVisibility  @default(PUBLIC) @map("marketplace_visibility")
  priceLabel                String?                        @map("price_label")
  priceCurrency             String?                        @map("price_currency")
  isFeatured                Boolean                        @default(false) @map("is_featured")
  licensingNotes            String?                        @map("licensing_notes")
  createdAt                 DateTime                       @default(now()) @map("created_at")
  updatedAt                 DateTime                       @updatedAt @map("updated_at")
  events                    Event[]
  versions                  TemplateVersion[]              @relation("TemplateVersions")
  currentPublishedVersion   TemplateVersion?               @relation("CurrentPublishedVersion", fields: [currentPublishedVersionId], references: [id], onDelete: SetNull)
  assets                    TemplateAsset[]

  @@index([category])
  @@index([isActive, sortOrder])
  @@map("templates")
}

/// Immutable published snapshots; drafts are mutable until publish
model TemplateVersion {
  id                String                @id @default(uuid()) @db.Uuid
  templateId        String                @map("template_id") @db.Uuid
  version           Int
  status            TemplateVersionStatus @default(DRAFT)
  /// Envelope format version for steps_schema / dataModel / settings
  schemaVersion     Int                   @default(1) @map("schema_version")
  stepsSchema       Json                  @map("steps_schema")
  dataModel         Json                  @default("{}") @map("data_model")
  settings          Json                  @default("{}")
  sampleData        Json                  @default("{}") @map("sample_data")
  releaseNotes      String?               @map("release_notes")
  breakingChange    Boolean               @default(false) @map("breaking_change")
  migrationNotes    String?               @map("migration_notes")
  createdByUserId   String?               @map("created_by_user_id") @db.Uuid
  publishedByUserId String?               @map("published_by_user_id") @db.Uuid
  publishedAt       DateTime?             @map("published_at")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  template          Template              @relation("TemplateVersions", fields: [templateId], references: [id], onDelete: Restrict)
  createdBy         User?                 @relation("TemplateVersionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  publishedBy       User?                 @relation("TemplateVersionPublishedBy", fields: [publishedByUserId], references: [id], onDelete: SetNull)
  events            Event[]
  currentFor        Template?             @relation("CurrentPublishedVersion")
  telemetry         TemplateTelemetryEvent[]

  @@unique([templateId, version])
  @@index([templateId, status])
  @@map("template_versions")
}

model TemplateAsset {
  id        String   @id @default(uuid()) @db.Uuid
  templateId String  @map("template_id") @db.Uuid
  assetType String?  @map("asset_type")
  url       String
  mimeType  String?  @map("mime_type")
  sizeBytes Int?     @map("size_bytes")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  template  Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, sortOrder])
  @@map("template_assets")
}

model Event {
  id                String           @id @default(uuid()) @db.Uuid
  /// Legacy anonymous owner (nullable after claim / for new user-owned events)
  creatorId         String?          @map("creator_id") @db.Uuid
  /// Authenticated owner — required for new cards after login
  ownerUserId       String?          @map("owner_user_id") @db.Uuid
  claimedAt         DateTime?        @map("claimed_at")
  name              String
  eventDate         DateTime?        @map("event_date")
  templateId        String?          @map("template_id") @db.Uuid
  /// Pinned published template version — guest runtime must use this
  templateVersionId String?          @map("template_version_id") @db.Uuid
  templateData      Json             @default("{}") @map("template_data")
  pinHash           String           @map("pin_hash")
  status            String           @default("active")
  viewCount         Int              @default(0) @map("view_count")
  expiresAt         DateTime?        @map("expires_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  creator           Creator?         @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  owner             User?            @relation("EventOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  template          Template?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  templateVersion   TemplateVersion? @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)
  accessLogs        EventAccessLog[]
  assets            EventAsset[]
  telemetry         TemplateTelemetryEvent[]

  @@index([creatorId])
  @@index([ownerUserId])
  @@index([templateId])
  @@index([templateVersionId])
  @@map("events")
}

model EventAccessLog {
  id          String   @id @default(uuid()) @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  ipAddress   String?  @map("ip_address")
  success     Boolean
  attemptedAt DateTime @default(now()) @map("attempted_at")
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_access_logs")
}

model EventAsset {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  assetType String?  @map("asset_type")
  url       String
  mimeType  String?  @map("mime_type")
  sizeBytes Int?     @map("size_bytes")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, sortOrder])
  @@map("event_assets")
}

/// Privacy-minimal guest funnel telemetry (no raw IP / user-agent)
model TemplateTelemetryEvent {
  id                String                @id @default(uuid()) @db.Uuid
  eventId           String                @map("event_id") @db.Uuid
  templateVersionId String                @map("template_version_id") @db.Uuid
  kind              TemplateTelemetryKind
  stepKey           String?               @map("step_key")
  stepType          String?               @map("step_type")
  stepIndex         Int?                  @map("step_index")
  deviceClass       DeviceClass           @default(UNKNOWN) @map("device_class")
  createdAt         DateTime              @default(now()) @map("created_at")
  event             Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  templateVersion   TemplateVersion       @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)

  @@index([templateVersionId, kind, createdAt])
  @@index([eventId, createdAt])
  @@map("template_telemetry_events")
}

/// Security / admin action audit (no secrets in metadata)
model AuditLog {
  id           String       @id @default(uuid()) @db.Uuid
  occurredAt   DateTime     @default(now()) @map("occurred_at")
  actorUserId  String?      @map("actor_user_id") @db.Uuid
  actorRole    String?      @map("actor_role")
  actorEmail   String?      @map("actor_email")
  action       String
  resourceType String       @map("resource_type")
  resourceId   String?      @map("resource_id")
  outcome      AuditOutcome @default(SUCCESS)
  ipHash       String?      @map("ip_hash")
  deviceId     String?      @map("device_id")
  requestId    String?      @map("request_id")
  summaryTh    String       @map("summary_th")
  metadata     Json         @default("{}")
  actor        User?        @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([occurredAt(sort: Desc)])
  @@index([action, occurredAt])
  @@index([resourceType, resourceId])
  @@index([actorUserId, occurredAt])
  @@map("audit_logs")
}

/// Ops / error system log (no secrets)
model SystemLog {
  id          String         @id @default(uuid()) @db.Uuid
  occurredAt  DateTime       @default(now()) @map("occurred_at")
  level       SystemLogLevel @default(INFO)
  source      String
  code        String
  message     String
  requestId   String?        @map("request_id")
  route       String?
  httpStatus  Int?           @map("http_status")
  durationMs  Int?           @map("duration_ms")
  metadata    Json           @default("{}")
  errorName   String?        @map("error_name")
  stackDigest String?        @map("stack_digest")

  @@index([occurredAt(sort: Desc)])
  @@index([level, occurredAt])
  @@index([source, code, occurredAt])
  @@map("system_logs")
}

/// Public / guest support cases (login optional)
model SupportCase {
  id                    String               @id @default(uuid()) @db.Uuid
  caseNumber            Int                  @default(autoincrement()) @map("case_number")
  status                SupportCaseStatus    @default(NEW)
  priority              SupportCasePriority  @default(NORMAL)
  name                  String
  subject               String
  detail                String               @db.Text
  usernameOrEmail       String?              @map("username_or_email")
  contactEmail          String               @map("contact_email")
  phone                 String?
  assignedAdminId       String?              @map("assigned_admin_id") @db.Uuid
  linkedUserId          String?              @map("linked_user_id") @db.Uuid
  publicAccessTokenHash String               @map("public_access_token_hash")
  ipHash                String?              @map("ip_hash")
  deviceId              String?              @map("device_id")
  userAgentDigest       String?              @map("user_agent_digest")
  claimedAt             DateTime?            @map("claimed_at")
  closedAt              DateTime?            @map("closed_at")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  assignedAdmin         User?                @relation("SupportCaseAssignee", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  linkedUser            User?                @relation("SupportCaseLinkedUser", fields: [linkedUserId], references: [id], onDelete: SetNull)
  messages              SupportCaseMessage[]
  statusHistory         SupportCaseStatusHistory[]
  conversation          SupportConversation?

  @@index([status, createdAt])
  @@index([assignedAdminId, status])
  @@index([contactEmail])
  @@map("support_cases")
}

model SupportCaseMessage {
  id         String                    @id @default(uuid()) @db.Uuid
  caseId     String                    @map("case_id") @db.Uuid
  visibility SupportMessageVisibility  @default(PUBLIC)
  senderType SupportSenderType         @map("sender_type")
  senderUserId String?                 @map("sender_user_id") @db.Uuid
  body       String                    @db.Text
  createdAt  DateTime                  @default(now()) @map("created_at")
  case       SupportCase               @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
  @@map("support_case_messages")
}

model SupportCaseStatusHistory {
  id         String            @id @default(uuid()) @db.Uuid
  caseId     String            @map("case_id") @db.Uuid
  fromStatus SupportCaseStatus? @map("from_status")
  toStatus   SupportCaseStatus @map("to_status")
  changedByUserId String?      @map("changed_by_user_id") @db.Uuid
  note       String?
  createdAt  DateTime          @default(now()) @map("created_at")
  case       SupportCase       @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
  @@map("support_case_status_history")
}

/// Logged-in user ↔ admin chat (1 conversation per user)
model SupportConversation {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @unique @map("user_id") @db.Uuid
  supportCaseId   String?          @unique @map("support_case_id") @db.Uuid
  lastMessageAt   DateTime?        @map("last_message_at")
  userUnreadCount Int              @default(0) @map("user_unread_count")
  adminUnreadCount Int             @default(0) @map("admin_unread_count")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  user            User             @relation("SupportConversationUser", fields: [userId], references: [id], onDelete: Cascade)
  supportCase     SupportCase?     @relation(fields: [supportCaseId], references: [id], onDelete: SetNull)
  messages        SupportMessage[]

  @@index([lastMessageAt])
  @@map("support_conversations")
}

model SupportMessage {
  id             String                   @id @default(uuid()) @db.Uuid
  conversationId String                   @map("conversation_id") @db.Uuid
  senderType     SupportSenderType        @map("sender_type")
  senderUserId   String?                  @map("sender_user_id") @db.Uuid
  visibility     SupportMessageVisibility @default(PUBLIC)
  body           String                   @db.Text
  createdAt      DateTime                 @default(now()) @map("created_at")
  conversation   SupportConversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User?                    @relation("SupportMessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@map("support_messages")
}

/// In-app notifications (email via NotificationAdapter)
model AppNotification {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  title       String
  body        String
  href        String?
  readAt      DateTime? @map("read_at")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("app_notifications")
}
