# Neon / Postgres — ใช้ pooled URL สำหรับแอป
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler/neondb?sslmode=require"

# Direct (ไม่มี pgbouncer) — สำหรับ prisma migrate
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Local Docker ตัวอย่าง (ถ้าไม่ใช้ Neon):
# DATABASE_URL="postgresql://wishflow:wishflow@localhost:5435/wish_flow?schema=public"
# DIRECT_URL="postgresql://wishflow:wishflow@localhost:5435/wish_flow?schema=public"

UNLOCK_JWT_SECRET="change-me-to-a-long-random-string"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-hex-32"
# AUTH_URL="http://localhost:3000"

# Bootstrap admin ตอน seed (optional)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-strong-password"

# Google OAuth (optional — ไม่ตั้งก็ใช้ได้แค่ email/password)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# Cloudflare R2 (optional local — ไม่ตั้งใช้ local uploads/; production guestbook photos ต้องตั้ง)
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET=""

# Turnstile CAPTCHA (optional — ไม่ตั้ง = stub ผ่าน)
# TURNSTILE_SECRET=""
